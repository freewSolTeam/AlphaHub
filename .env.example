# Salin ke `.env` — jangan commit `.env`

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

AUTH_SECRET="openssl rand -base64 32"
# Dev: http://localhost:3000 | Prod: https://www.alphahub.space
# AUTH_URL="http://localhost:3000"

AUTH_TWITTER_ID="your-twitter-client-id"
AUTH_TWITTER_SECRET="your-twitter-client-secret"
# AUTH_X_ALLOWLIST="handle1,handle2"

NEXT_PUBLIC_ROBINHOOD_RPC="https://rpc.mainnet.chain.robinhood.com"
NEXT_PUBLIC_REOWN_PROJECT_ID="your-reown-project-id"

PLATFORM_FEE_USDG="1.5"
CHECKOUT_ETH_USDG_RATE="3000"
NEXT_PUBLIC_CHECKOUT_ETH_USDG_RATE="3000"

PLATFORM_TREASURY_WALLET="0xYOUR_PLATFORM_TREASURY_WALLET"
ESCROW_CONTRACT_ADDRESS="0xYOUR_DEPLOYED_CONTRACT_ADDRESS"
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS="0xYOUR_DEPLOYED_CONTRACT_ADDRESS"
# NEXT_PUBLIC_TOKEN_CA="0xYOUR_TOKEN_CONTRACT_ADDRESS"

