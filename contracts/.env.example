# =============================================================================
# AlphaHubCheckout — env untuk deploy smart contract
# =============================================================================
#
# Script deploy (`npm run contracts:deploy`) membaca `.env` root LALU `contracts/.env`.
# Setelah deploy, tambahkan alamat contract ke root `.env`:
#   ESCROW_CONTRACT_ADDRESS=0x…
#   NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x…

# --- Wajib (masuk ke constructor smart contract) ---
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
PLATFORM_TREASURY_WALLET=0xYOUR_PLATFORM_TREASURY_WALLET

# RPC Robinhood Chain (gas deploy)
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# =============================================================================
# Fee platform — TERSIMPAN ON-CHAIN (public di AlphaHubCheckout.sol)
# =============================================================================
# Mapping env → variabel contract:
#   PLATFORM_TREASURY_WALLET  →  treasury()     wallet terima fee
#   PLATFORM_FEE_USDG_UNITS   →  usdgFee()      fee USDG (6 desimal, 1500000 = 1.5)
#   PLATFORM_FEE_ETH_WEI      →  ethFeeWei()    fee native ETH
#   USDG_TOKEN_ADDRESS        →  usdgToken()    immutable saat deploy
#
# Owner contract bisa update fee lewat setFees() — app baca langsung dari chain.

PLATFORM_FEE_USDG=1.5
PLATFORM_FEE_USDG_UNITS=1500000
# PLATFORM_FEE_ETH=0.0005
# PLATFORM_FEE_ETH_WEI=500000000000000
# CHECKOUT_ETH_USDG_RATE=3000
# USDG_TOKEN_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168

# =============================================================================
# Wallet kreator — TIDAK di env contract
# =============================================================================
# Payout kreator di-set per akun di app (Dashboard → Sales payout wallet).
# Saat checkout, buyer kirim `seller` address ke contract — dari database, bukan .env.
