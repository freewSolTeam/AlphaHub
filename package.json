{
  "name": "alphahub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:regen": "prisma generate && next dev",
    "build": "next build",
    "build:full": "prisma generate && next build",
    "start": "next start",
    "bot:telegram": "node --import tsx --env-file=.env ./scripts/telegram-bot.ts",
    "bot:telegram:deletewebhook": "node --env-file=.env ./scripts/telegram-deletewebhook.mjs",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:regen": "node scripts/prisma-regen.mjs",
    "db:studio": "prisma studio",
    "db:clear": "node scripts/clear-all-data.mjs",
    "db:clear-escrow": "node scripts/clear-escrow-purchases.mjs",
    "db:diversify-operators": "node --env-file=.env scripts/diversify-listing-operators.mjs",
    "contracts:build": "cd contracts && forge build",
    "contracts:deploy": "node scripts/deploy-alphahub-checkout.mjs",
    "contracts:verify": "node scripts/verify-alphahub-contract.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "5.22.0",
    "@reown/appkit": "^1.8.22",
    "@reown/appkit-adapter-wagmi": "^1.8.22",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/blob": "^2.3.3",
    "@wagmi/connectors": "^8.0.22",
    "@wagmi/core": "^3.6.1",
    "buffer": "^6.0.3",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegraf": "^4.16.3",
    "viem": "^2.55.0",
    "wagmi": "^3.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
